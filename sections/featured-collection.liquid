{% liquid
  assign collection = collections[section.settings.collection]
  assign product_limit = section.settings.product_limit
%}

<section class="section">
  <div class="page-width">
    <div class="section__head">
      <div>
        {% if section.settings.kicker != blank %}
          <p class="section__kicker">{{ section.settings.kicker }}</p>
        {% endif %}
        <h2 class="section__title">{{ section.settings.heading }}</h2>
      </div>
      {% if collection != blank %}
        <a class="button button--secondary" href="{{ collection.url }}">View all</a>
      {% endif %}
    </div>

    <div class="product-grid">
      {% if collection != blank and collection.products_count > 0 %}
        {% for product in collection.products limit: product_limit %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <article class="product-card">
            <div class="product-card__media">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">Drop item {{ i }}</h3>
              <div class="price">Rs. 999.00</div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "First experiment"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fresh from the lab"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Products",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
