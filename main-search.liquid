<section class="section">
  <div class="page-width">
    <div class="section__head">
      <div>
        <p class="section__kicker">Find the thought</p>
        <h1 class="section__title">Search</h1>
      </div>
    </div>

    <form action="{{ routes.search_url }}" method="get" role="search" class="collection-toolbar">
      <input class="field" type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products">
      <button class="button" type="submit">Search</button>
    </form>

    {% if search.performed %}
      {% paginate search.results by 12 %}
        <div class="product-grid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              {% render 'product-card', product: item %}
            {% endif %}
          {% else %}
            <p class="rte">No results found.</p>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <div class="hero__actions" style="justify-content:center">
            {% if paginate.previous %}
              <a class="button button--secondary" href="{{ paginate.previous.url }}">Previous</a>
            {% endif %}
            {% if paginate.next %}
              <a class="button" href="{{ paginate.next.url }}">Next</a>
            {% endif %}
          </div>
        {% endif %}
      {% endpaginate %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Search"
}
{% endschema %}
