<section class="section">
  <div class="page-width">
    <div class="section__head">
      <div>
        <p class="section__kicker">Shop by idea</p>
        <h1 class="section__title">Collections</h1>
      </div>
    </div>
    <div class="product-grid">
      {% for collection in collections %}
        {% unless collection.handle == 'frontpage' %}
          <article class="product-card">
            <a href="{{ collection.url }}">
              <div class="product-card__media">
                {% if collection.featured_image %}
                  {{ collection.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '320, 520, 900', alt: collection.title }}
                {% else %}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              <div class="product-card__info">
                <h2 class="product-card__title">{{ collection.title }}</h2>
                <div class="price">{{ collection.products_count }} products</div>
              </div>
            </a>
          </article>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections list"
}
{% endschema %}
